<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<HBox prefWidth="960" prefHeight="600"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.dorm.auth.LoginController"
      style="-fx-background-color: #12131f;">

    <!-- Left Branding Panel -->
    <VBox HBox.hgrow="ALWAYS" spacing="16"
          style="-fx-background-color: #1a1b2e;">
        <padding><Insets top="60" right="50" bottom="60" left="50"/></padding>

        <!-- Logo Row -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="DL"
                   style="-fx-background-color: #f5c400; -fx-text-fill: #12131f; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 8; -fx-padding: 5 10;"/>
            <Label text="DormLink"
                   style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18px;"/>
        </HBox>

        <Label text="Dormitory Management System"
               style="-fx-text-fill: #8a8a9a; -fx-font-size: 11px;"/>

        <Region prefHeight="20"/>

        <Label text="Manage Your&#10;Dorm with ease."
               wrapText="true"
               style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 32px;"/>

        <Region prefHeight="10"/>

        <Label text="Register tenants, manage rooms,&#10;track payments and maintenance&#10;all in one place."
               wrapText="true"
               style="-fx-text-fill: #8a8a9a; -fx-font-size: 13px;"/>

        <Region VBox.vgrow="ALWAYS"/>

        <Label text="© 2026 DormLink · Dormitory Management System"
               style="-fx-text-fill: #8a8a9a; -fx-font-size: 10px;"/>
    </VBox>

    <!-- Right Form Panel -->
    <VBox HBox.hgrow="ALWAYS" spacing="6" alignment="CENTER"
          style="-fx-background-color: #12131f;">
        <padding><Insets top="60" right="50" bottom="60" left="50"/></padding>

        <Label text="Welcome back"
               style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 24px;"/>
        <Label text="Sign in to access your dashboard."
               style="-fx-text-fill: #8a8a9a; -fx-font-size: 13px;"/>

        <Region prefHeight="20"/>

        <Label text="USERNAME"
               style="-fx-text-fill: #8a8a9a; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 8 0 0 0;"/>
        <TextField fx:id="usernameField"
                   promptText="Enter your username"
                   maxWidth="Infinity"/>

        <Label text="PASSWORD"
               style="-fx-text-fill: #8a8a9a; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 8 0 0 0;"/>
        <PasswordField fx:id="passwordField"
                       promptText="••••••••"
                       maxWidth="Infinity"/>

        <Label text="ROLE"
               style="-fx-text-fill: #8a8a9a; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 8 0 0 0;"/>
        <ComboBox fx:id="roleComboBox" maxWidth="Infinity"/>

        <Region prefHeight="8"/>

        <Button text="Sign In →"
                onAction="#onLoginButtonClick"
                maxWidth="Infinity"
                style="-fx-background-color: #f5c400; -fx-text-fill: #12131f; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 12; -fx-background-radius: 8; -fx-cursor: hand;"/>

        <Label fx:id="errorLabel" text=""
               style="-fx-text-fill: #e05050; -fx-font-size: 13px;"/>
    </VBox>
</HBox>
