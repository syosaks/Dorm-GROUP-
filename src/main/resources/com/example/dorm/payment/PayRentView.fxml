<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="12.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.dorm.payment.PayRentController"
      prefWidth="900" prefHeight="600">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Pay Rent">
        <font><Font size="20.0" /></font>
    </Label>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Tenant:" minWidth="80"/>
        <ComboBox fx:id="tenantComboBox" prefWidth="220"/>
        <Label fx:id="monthlyRateLabel" text=""
               style="-fx-font-size: 13px; -fx-text-fill: #1565C0; -fx-font-weight: bold;"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Amount (₱):" minWidth="80"/>
        <TextField fx:id="amountField" promptText="Enter amount" prefWidth="200"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Month:" minWidth="80"/>
        <TextField fx:id="monthField" promptText="e.g. May 2026" prefWidth="200"/>
    </HBox>

    <Button text="Record Payment" onAction="#onPayButtonClick"
            style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 8 16;"/>

    <Separator/>

    <Label text="Payment History" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

    <TableView fx:id="paymentHistoryTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn text="Date" prefWidth="150"/>
            <TableColumn text="Amount (₱)" prefWidth="130"/>
            <TableColumn text="Month Covered" prefWidth="160"/>
            <TableColumn text="Status" prefWidth="120"/>
        </columns>
    </TableView>

    <Button text="Back to Dashboard" onAction="#onBackButtonClick"/>
</VBox>
