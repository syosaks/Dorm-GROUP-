<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.dorm.controller.AssignRoomController"
      prefWidth="900" prefHeight="600">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Assign Room">
        <font><Font size="20.0" /></font>
    </Label>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Tenant:"/>
        <ComboBox fx:id="tenantComboBox" prefWidth="200"/>
        <Label text="Room:"/>
        <ComboBox fx:id="roomComboBox" prefWidth="200"/>
        <Button text="Assign" onAction="#onAssignButtonClick"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
    </HBox>

    <Label text="Current Assignments" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

    <TableView fx:id="assignmentsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn text="Tenant Name" prefWidth="200"/>
            <TableColumn text="Room Number" prefWidth="150"/>
            <TableColumn text="Capacity" prefWidth="100"/>
            <TableColumn text="Monthly Rate" prefWidth="150"/>
        </columns>
    </TableView>

    <Button text="Back" onAction="#onBackButtonClick"/>
</VBox>
