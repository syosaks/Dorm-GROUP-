<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.dorm.controller.ReserveRoomController"
      prefWidth="900" prefHeight="600">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Reserve a Room">
        <font><Font size="20.0" /></font>
    </Label>

    <TableView fx:id="roomsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn text="Room Number" prefWidth="150"/>
            <TableColumn text="Capacity" prefWidth="100"/>
            <TableColumn text="Status" prefWidth="120"/>
            <TableColumn text="Monthly Rate" prefWidth="150"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Reserve Selected Room" onAction="#onReserveButtonClick"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
        <Button text="Back" onAction="#onBackButtonClick"/>
    </HBox>
</VBox>
