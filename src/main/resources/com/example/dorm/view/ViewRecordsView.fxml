<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.dorm.controller.ViewRecordsController"
      prefWidth="900" prefHeight="600">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="View Records">
        <font><Font size="20.0" /></font>
    </Label>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Search..." HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="filterComboBox" prefWidth="150"/>
        <Button text="Search" onAction="#onSearchButtonClick"/>
    </HBox>

    <TableView fx:id="recordsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn text="ID" prefWidth="60"/>
            <TableColumn text="Name" prefWidth="200"/>
            <TableColumn text="Details" prefWidth="300"/>
            <TableColumn text="Status" prefWidth="120"/>
        </columns>
    </TableView>

    <Button text="Back" onAction="#onBackButtonClick"/>
</VBox>
